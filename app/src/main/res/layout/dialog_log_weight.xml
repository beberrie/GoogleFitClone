<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Top section: close + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginBottom="8dp">

        <!-- Close button aligned to the right -->
        <ImageButton
            android:id="@+id/btn_close_weight"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            app:srcCompat="@drawable/ic_close" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_weight_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/font_montserrat"
            android:text="Log Weight"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textFontWeight="600" />

    </LinearLayout>

    <!-- Center section: input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <EditText
            android:id="@+id/et_weight_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:inputType="numberDecimal"
            android:fontFamily="@font/font_montserrat"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textFontWeight="600"
            android:background="@android:color/transparent"
            android:hint="0.0"
            android:textColorHint="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/font_montserrat"
            android:text="kg"
            android:textColor="@color/text_secondary"
            android:textSize="20sp" />

    </LinearLayout>

    <!-- Bottom: Save button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_weight"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Save weight"
        android:fontFamily="@font/font_montserrat"
        android:textSize="15sp"
        android:backgroundTint="@color/accent_blue"
        app:cornerRadius="12dp" />

</LinearLayout>